# =============================
# LUMEN Environment Configuration
# =============================
# Copy this file to .env and adjust values as needed.
# For Docker, most values are already configured in docker-compose files.

# =============================
# FRONTEND
# =============================
# Dev (Vite proxy)    : /api/lumen
# Docker dev          : /api/lumen  (Vite proxy handles it)
# Docker prod (nginx) : /api/lumen (nginx reverse proxy)
VITE_API_URL=/api/lumen

# WebSocket URL for real-time monitoring
# Dev local           : ws://localhost:9000/ws
# Docker dev          : ws://localhost:9000/ws
# Docker prod (nginx) : ws://localhost/ws  (goes through nginx)
VITE_WS_URL=ws://localhost:9000/ws

# =============================
# BACKEND (server-side only)
# =============================
# Local dev           : postgres://lumen:Lum3n.pasS!@localhost:5432/lumendb
# Docker              : postgres://lumen:Lum3n.pasS!@db:5432/lumendb
POSTGRES_URL=postgres://lumen:Lum3n.pasS!@db:5432/lumen
PORT=9000
SECRET_KEY=a0a1e1deffrgf9èù!er14!
NODE_ENV=development

# =============================
# SCADA / MQTT
# =============================
# Public broker (dev) : mqtt://broker.hivemq.com:1883
# Docker internal     : mqtt://mosquitto:1883
MQTT_URL=mqtt://mosquitto:1883
MQTT_TOPIC=centrale/+/data

# =============================
# SSL / HTTPS (production with Certbot)
# =============================
CERTBOT_EMAIL=jonhson.ratsimbaherison@staff.blueline.mg
CERTBOT_DOMAIN=lumen.blueline.grenn
CERTBOT_FLAGS=--dry-run
